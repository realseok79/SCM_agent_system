MOCK_API_HOST=http://localhost:8080
MOCK_API_KEY=your_api_key_here

SIMULATION_DAYS=100
SIMULATION_SPEED_SECONDS=300

MAX_ORDER_CEILING_RATIO=3.0
STOCKOUT_ALERT_THRESHOLD=0.01

LOG_LEVEL=INFO

# Action Agent Guardrails
ABSOLUTE_MAX_CAPACITY=5000.0
ORDER_OUTPUT_PATH=outputs/order_list.json
REPORT_OUTPUT_PATH=outputs/emergency_report.json
HISTORY_OUTPUT_PATH=outputs/order_history.json
