# SCM Agent System - Environment Configuration Template

# ── API Keys Configuration (Optional, Fallback to deterministic mock data if empty)
# 기상 정보 실시간 수집을 위한 OpenWeatherMap API Key
OPENWEATHER_API_KEY=

# 대한민국 기상청 실시간 API 수집을 위한 Auth Key (apihub.kma.go.kr)
KMA_API_KEY=

# SCM AI의 리스크 점수 계산 및 처방 보고서 생성을 위한 OpenAI API Key
OPENAI_API_KEY=

# ── Data & Output Paths Configuration
SCM_DATA_PATH=outputs/scm_dummy_data.json
ORDER_OUTPUT_PATH=outputs/order_list.json
HISTORY_OUTPUT_PATH=outputs/order_history.json
REPORT_OUTPUT_PATH=outputs/emergency_report.json

# ── Network Settings
MOCK_API_HOST=http://localhost:8080
MOCK_API_PORT=8080

# ── Simulation Settings (100 days stress test simulation speed)
SIMULATION_DAYS=100
SIMULATION_SPEED_SECONDS=300

# ── Guardrails Settings (Limits relative to 30d moving average)
MAX_ORDER_CEILING_RATIO=3.0
ABSOLUTE_MAX_CAPACITY=5000.0
