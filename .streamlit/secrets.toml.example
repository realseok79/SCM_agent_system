# ──────────────────────────────────────────────────────────
# SCM Agent System — API 키 설정 템플릿
# ──────────────────────────────────────────────────────────
# 이 파일을 secrets.toml로 복사한 후 API 키를 입력하세요:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# 각 키 발급 방법:
#   KMA_API_KEY       → https://apihub.kma.go.kr (회원가입 후 즉시 발급)
#   FRED_API_KEY      → https://fred.stlouisfed.org/docs/api/api_key.html (무료)
#   OPENWEATHER_API_KEY → https://openweathermap.org/appid (무료 tier)
#
# ⚠️ 이 파일(secrets.toml)은 .gitignore에 의해 GitHub에 올라가지 않습니다.
# ──────────────────────────────────────────────────────────

KMA_API_KEY = ""
FRED_API_KEY = ""
OPENWEATHER_API_KEY = ""
