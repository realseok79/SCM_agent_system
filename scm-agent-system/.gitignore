# ====================================================================
# SCM Agent System Subdirectory .gitignore
# ====================================================================

# --- OS & IDEs ---
.DS_Store
.vscode/
.idea/
.antigravity/

# --- Virtual Environments (Python) ---
myenv/
venv/
.venv/

# --- Python Cache & Temporary Files ---
__pycache__/
*.pyc
.pytest_cache/
.coverage
.ipynb_checkpoints/

# --- Gradle & Build outputs ---
.gradle/
build/

# --- Secrets & Local Configurations ---
.env
.streamlit/secrets.toml
!.streamlit/config.toml

# --- Database & Runtime Files ---
data/*.db
data/*.db-shm
data/*.db-wal
simulator/data/*.db
simulator/data/*.db-shm
simulator/data/*.db-wal
data/last_known_values.json
data/last_known_values.json.tmp
*.log
*_output.txt

# --- Machine Learning & Large Artifacts ---
*.pt
*.onnx
*.xlsx

# --- Outputs / Artifacts ---
outputs/*.json

# --- Data files (CSV) ---
# By default, ignore all CSVs in this directory
*.csv

# Exceptions: explicit files that MUST be tracked
!data/sample_inventory_data.csv
!data/wmo_station_master.csv
!tests/mock_data.csv
!outputs/scm_dummy_data.json
!outputs/scm_dummy_data.csv
!config/decision_rules.yaml